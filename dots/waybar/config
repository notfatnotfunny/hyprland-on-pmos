[{
	"layer": "top",
	"position": "top",
	"margin": "10 0 0 0",
	"modules-left": ["clock", "custom/fullscreen"],
	"modules-right": ["network", "custom/battery", "pulseaudio", "custom/power"],

	"network": {
		"format-wifi": "ΎΘτ",
	},
	"clock": {
		// "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
		// "format-alt": "{:%Y-%m-%d}"
		"format": "{:%a %d %H:%M}"
	},
	"custom/fullscreen": {
		"format": "ΎΒξ",
		"on-click": "hyprctl dispatch fullscreen"
	},
	"pulseaudio": {
		"format": "{volume}% {icon}",
		"format-bluetooth": "{volume}% {icon}ΎΛΦ {format_source}",
		"format-bluetooth-muted": "Ύγσ {icon}ΎΛΦ {format_source}",
		"format-muted": "0% {icon}",
		"format-source": "{volume}% ΎΕ░",
		"format-source-muted": "ΎΕ▒",
		"format-icons": {
			"headphone": "ΎΑξ",
			"hands-free": "ΎΑξ",
			"headset": "ΎΑξ",
			"phone": "ΎΓΧ",
			"portable": "ΎΓΧ",
			"car": "ΎΗ╣",
			"default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
		},
	},
	"custom/battery": {
		"format": "{percentage}% {icon}",
		"format-icons": {"default": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"], "charging": "ΎΔπ"},
		"return-type": "json",
		"exec": "~/.config/waybar/scripts/battery.sh",
		"interval": 2
	},
	"custom/power": {
		"format": "ΎΑΣ ",
		"on-click": "hyprctl dispatch exit"
	}
},
{
	"layer": "top",
	"position": "bottom",
	"margin": "0 30 5 30",
	"fixed-center": "true",
	"modules-left": ["custom/switch"],
	"modules-center": ["custom/home"],
	"modules-right": ["custom/kill"],
	"custom/switch": {
		"format": "ΎΞμ",
		"on-click": "switch"
	},
	"custom/home": {
		"format": "ΌΗ░",
		"on-click": "pidof sysmenu && pkill -RTMIN sysmenu || sysmenu"
	},
	"custom/kill": {
		"format": "ΎΑΞ",
		"on-click": "hyprctl dispatch killactive"
	},

}
]
